# Template for Streamlit Community Cloud secrets.
#
# Copy the relevant section into the Streamlit Cloud app's
# Advanced Settings → Secrets panel (not into a file in the repo;
# this template is only for documentation).
#
# When no Postgres secrets are set, the dashboard falls back to the
# parquet files shipped in data/ and all pages render correctly.

# --- Optional: managed Postgres (Supabase / Neon / RDS / etc.) ---
#
# dashboard/utils.py reads these keys via os.environ. Streamlit Cloud
# exposes secrets as environment variables at runtime, so you can
# set them either as a flat list or nested under [postgres].

RESALEIQ_PG_HOST = "db.example.supabase.co"
RESALEIQ_PG_PORT = "5432"
RESALEIQ_PG_DB = "resaleiq"
RESALEIQ_PG_USER = "resaleiq_reader"
RESALEIQ_PG_PASSWORD = "replace-me"

# --- Optional: disable Postgres entirely (force parquet-only mode) ---
#
# Setting HOST to the literal string "__disabled__" will short-circuit
# the Postgres attempt and always read parquet. Useful if you want the
# Streamlit Cloud deploy to be stateless regardless of DB availability.
#
# RESALEIQ_PG_HOST = "__disabled__"
