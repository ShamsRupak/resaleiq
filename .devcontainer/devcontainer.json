{
  "name": "ResaleIQ",
  "image": "mcr.microsoft.com/devcontainers/python:1-3.11-bookworm",
  "features": {
    "ghcr.io/va-h/devcontainers-features/uv:1": {}
  },
  "customizations": {
    "codespaces": {
      "openFiles": ["README.md", "dashboard/app.py"]
    },
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "charliermarsh.ruff"
      ]
    }
  },
  "updateContentCommand": "uv sync --all-extras",
  "postAttachCommand": {
    "server": "uv run streamlit run dashboard/app.py --server.enableCORS false --server.enableXsrfProtection false"
  },
  "portsAttributes": {
    "8501": {"label": "Application", "onAutoForward": "openPreview"}
  },
  "forwardPorts": [8501]
}